# Normalize line endings for all text files to LF in the repo,
# and let Git convert to the OS native ending on checkout.
* text=auto eol=lf

# Explicitly mark Python and config files as text
*.py   text eol=lf
*.toml text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.cfg  text eol=lf

# Binary files – no conversion
*.zip  binary
*.pyc  binary
